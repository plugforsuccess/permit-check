# PermitCheck environment — see src/lib/env.ts for the Zod schema (single
# source of truth). Server fails to start on misconfiguration.

# ----------------------------------------------------------------------------
# Core
# ----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Anthropic — model IDs pinned per SPEC §15
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ORCHESTRATOR=claude-sonnet-4-5
ANTHROPIC_MODEL_REPORTER=claude-opus-4-7

# ----------------------------------------------------------------------------
# Stripe
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------------------------------------
# Google
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_SERVER_KEY=

# ----------------------------------------------------------------------------
# Inngest (forward-look — required when PR3 lands)
# ----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----------------------------------------------------------------------------
# Email (Resend)
# ----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=reports@permitcheck.org
HEALTH_CHECK_ALERT_EMAIL=

# ----------------------------------------------------------------------------
# Monitoring (Axiom). Sentry is deferred to PR8.
# Optional: logger no-ops on Axiom transport when these are empty.
# ----------------------------------------------------------------------------
AXIOM_TOKEN=
AXIOM_DATASET=

# ----------------------------------------------------------------------------
# Rate limiting (Upstash Redis)
# ----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------------------------------
# Accela (optional — current scraper goes through the public portal)
# ----------------------------------------------------------------------------
ACCELA_APP_ID=
ACCELA_APP_SECRET=
ACCELA_ENVIRONMENT=PROD

# ----------------------------------------------------------------------------
# Property data enrichment (optional)
# ----------------------------------------------------------------------------
REAPI_API_KEY=

# ----------------------------------------------------------------------------
# Cron auth
# ----------------------------------------------------------------------------
CRON_SECRET=

# ----------------------------------------------------------------------------
# Affiliate IDs (optional)
# ----------------------------------------------------------------------------
HOMEADVISOR_AFFILIATE_ID=
LENDINGTREE_AFFILIATE_ID=
AVVO_AFFILIATE_ID=
NEXT_PUBLIC_AFFILIATE_INSPECTOR=
NEXT_PUBLIC_AFFILIATE_CONTRACTOR=
NEXT_PUBLIC_AFFILIATE_MORTGAGE=
NEXT_PUBLIC_AFFILIATE_ATTORNEY=
NEXT_PUBLIC_AFFILIATE_AGENT=

# ----------------------------------------------------------------------------
# Analytics (optional)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ----------------------------------------------------------------------------
# Feature flags — string "true"/"false", parsed to booleans by env.ts.
# All default false.
# ----------------------------------------------------------------------------
USE_INNGEST_REPORTS=false
AUTO_DELIVER_REPORTS=false
LOG_FULL_ADDRESS=false
FETCH_INSPECTION_HISTORY=false
